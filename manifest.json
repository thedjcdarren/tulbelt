{
  "manifest_version": 3,
  "name": "Tulbelt",
  "version": "0.1.1",
  "description": "Quality-of-life toggles for tulip.co.",
  "permissions": [
    "declarativeNetRequestWithHostAccess",
    "storage",
    "webNavigation",
    "tabs"
  ],
  "host_permissions": [
    "*://*.tulip.co/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.tulip.co/*"],
      "js": ["content.js", "auto-snapshot.js", "hide-legacy.js", "disable-tooltips.js", "hide-view-only-triggers.js", "move-variables-to-toolbar.js", "hide-app-editor-chrome.js", "compact-app-editor-header.js", "dark-mode.js", "strip-tab-title-prefix.js", "filters-builder.js", "expression-editor-fuzzy.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.tulip.co/*"],
      "js": ["context-menu-copy-cut.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["*://*.tulip.co/*"],
      "js": ["expression-editor-fuzzy-main.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tulbelt",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
